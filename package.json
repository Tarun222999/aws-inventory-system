{
  "name": "aws-order-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "db:generate": "npm run db:generate --workspace @order-platform/database",
    "db:migrate": "npm run db:migrate --workspace @order-platform/database",
    "dev:api": "npm run dev --workspace @order-platform/api",
    "dev:frontend": "npm run dev --workspace @order-platform/frontend",
    "dev:worker": "npm run dev --workspace @order-platform/worker",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "22.16.5",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0"
  }
}
