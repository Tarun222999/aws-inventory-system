# Local development placeholders only. Copy this file to .env.
POSTGRES_DB=order_platform
POSTGRES_USER=order_platform
POSTGRES_PASSWORD=local-development-only
DATABASE_URL=postgresql://order_platform:local-development-only@localhost:5432/order_platform
SHUTDOWN_TIMEOUT_MS=10000
API_PORT=3000
WORKER_POLL_INTERVAL_MS=1000
WORKER_LEASE_TIMEOUT_MS=30000
WORKER_RETRY_DELAY_MS=1000
WORKER_MAX_ATTEMPTS=3
WORKER_PROCESSING_DELAY_MS=250
